{
  "name": "a11y-mcp",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "LetsTN",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LetsTN/a11y-mcp"
  },
  "homepage": "https://github.com/LetsTN/a11y-mcp#readme",
  "bugs": {
    "url": "https://github.com/LetsTN/a11y-mcp/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "wcag22",
    "accessmonitor",
    "html",
    "jsx",
    "tsx",
    "mcp",
    "copilot"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "a11y-mcp.validateFile",
        "title": "%command.validateFile.title%",
        "category": "%command.category%"
      },
      {
        "command": "a11y-mcp.validateWorkspace",
        "title": "%command.validateWorkspace.title%",
        "category": "%command.category%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "a11y-mcp.wcagLevel": {
          "type": "string",
          "enum": [
            "A",
            "AA",
            "AAA"
          ],
          "default": "AAA",
          "description": "%config.wcagLevel.description%"
        },
        "a11y-mcp.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.html",
            "**/*.jsx",
            "**/*.tsx"
          ],
          "description": "%config.include.description%"
        },
        "a11y-mcp.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**"
          ],
          "description": "%config.exclude.description%"
        }
      }
    },
    "languageModelTools": [
      {
        "name": "a11y_validate_file",
        "tags": [
          "accessibility",
          "a11y",
          "wcag",
          "html",
          "jsx"
        ],
        "displayName": "%tool.validateFile.displayName%",
        "modelDescription": "%tool.validateFile.modelDescription%",
        "canBeReferencedInPrompt": true,
        "icon": "$(eye)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "%tool.validateFile.input.filePath%"
            }
          },
          "required": [
            "filePath"
          ]
        }
      },
      {
        "name": "a11y_validate_workspace",
        "tags": [
          "accessibility",
          "a11y",
          "wcag",
          "workspace"
        ],
        "displayName": "%tool.validateWorkspace.displayName%",
        "modelDescription": "%tool.validateWorkspace.modelDescription%",
        "canBeReferencedInPrompt": true,
        "icon": "$(search)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "folder": {
              "type": "string",
              "description": "%tool.validateWorkspace.input.folder%"
            },
            "maxFiles": {
              "type": "number",
              "description": "%tool.validateWorkspace.input.maxFiles%"
            }
          }
        }
      },
      {
        "name": "a11y_get_rule",
        "tags": [
          "accessibility",
          "a11y",
          "wcag",
          "rules"
        ],
        "displayName": "%tool.getRule.displayName%",
        "modelDescription": "%tool.getRule.modelDescription%",
        "canBeReferencedInPrompt": true,
        "icon": "$(info)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "ruleId": {
              "type": "string",
              "description": "%tool.getRule.input.ruleId%"
            }
          },
          "required": [
            "ruleId"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "package": "vsce package --no-dependencies",
    "publish:ovsx": "ovsx publish *.vsix -p $OVSX_PAT",
    "publish:vsce": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "cheerio": "^1.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.9.5",
    "typescript": "^5.7.0"
  }
}
